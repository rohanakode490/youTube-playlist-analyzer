{
    "manifest_version": 3,
    "name": "YouTube Playlist Analyzer",
    "version": "1.0",
    "description": "Analyze YouTube playlists: count, duration, sort, and range selection.",
    "permissions": [],
    "host_permissions": [
        "*://*.youtube.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/playlist*"
            ],
            "js": [
                "content.js"
            ],
            "css": [],
            "run_at": "document_idle"
        }
    ]
}
